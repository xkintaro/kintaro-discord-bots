DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

#İnsanların botu kendi sunucularına eklemelerini için izin verir.
KINTARO_BOT_PUBLIC=false
KINTARO_BOT_QUIT_UNVERIFIED_ALL_SERVERS=true 

#✧✧✧✧✧✧✧✧✧✧kintaroRolePicker.js✧✧✧✧✧✧✧✧✧✧#
#Sunucuda, kullanıcıların belirlenen bir kanalda rol seçim işlemlerini yapmasını sağlar.
KINTARO_ROLE_PICKER_CHANNEL=

#✧✧✧✧✧✧✧✧✧✧kintaroEntryExit.js✧✧✧✧✧✧✧✧✧✧#
#Sunucuda, belirlenen bir kanalda, kullanıcıların giriş ve çıkışlarını gösterir.
KINTARO_ENTRY_EXIT=true
KINTARO_ENTRY_EXIT_WELCOME_CHANNEL=

#✧✧✧✧✧✧✧✧✧✧kintaroEntryExitGuard.js✧✧✧✧✧✧✧✧✧✧#
#Sunucuda, belirlenen bir kanalda, kullanıcıların giriş ve çıkışlarını gösterir ve kayıt işlemlerini yönetir.
KINTARO_ENTRY_EXIT_GUARD=true
KINTARO_ENTRY_EXIT_GUARD_WELCOME_CHANNEL=
KINTARO_ENTRY_EXIT_GUARD_UNVERIFIED_ROLE=
KINTARO_ENTRY_EXIT_GUARD_VERIFIED_ROLE=

#✧✧✧✧✧✧✧✧✧✧kintaroJumpVoiceAuto.js✧✧✧✧✧✧✧✧✧✧#
#Bot, sunucudaki belirlenen bir ses kanalına belirli aralıklarla otomatik olarak katılır.
KINTARO_JUMP_VOICE_AUTO=true
KINTARO_JUMP_VOICE_AUTO_JOIN_INTERVAL=300
KINTARO_JUMP_VOICE_AUTO_CHANNEL_ID=

#✧✧✧✧✧✧✧✧✧✧kintaroAutoResponder.js✧✧✧✧✧✧✧✧✧✧#
#Bot, sunucuda yazılan belirli metinlere, otomatik olarak önceden tanımlanmış yanıtlar verir.
KINTARO_AUTO_RESPONSER=true 